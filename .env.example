# Catalogue service local env
# Local profile loads this file first, then falls back to bidmart-infrastructure/.env when present

PORT=8081
# Production VPS + Supabase (see bidmart-infrastructure/docs/DEPLOYMENT_URLS.md):
# SPRING_DATASOURCE_URL=jdbc:postgresql://db.mekfvqtoeuwjiafltier.supabase.co:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=<catalogue-supabase-password>
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bidmart_catalogue
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# Swagger UI (docker-compose)
SWAGGER_UI_PORT=8088
