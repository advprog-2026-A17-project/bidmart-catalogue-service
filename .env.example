# Catalogue service local env
# Local profile loads this file first, then falls back to bidmart-infrastructure/.env when present

PORT=8081
# Production VPS + Supabase (see bidmart-infrastructure/docs/DEPLOYMENT_URLS.md):
# IMPORTANT: VPS host has no IPv6. Use Supabase Session Pooler (IPv4):
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres.mekfvqtoeuwjiafltier
# SPRING_DATASOURCE_PASSWORD=<catalogue-supabase-password>
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bidmart_catalogue
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# JWT secret (must match Heroku auth's AUTH_JWT_SECRET in prod/staging)
BIDMART_JWT_SECRET=bidmart-auth-secret-key-bidmart-auth-secret-key

# Internal service token (must match Heroku auth's GATEWAY_INTERNAL_TOKEN)
GATEWAY_INTERNAL_TOKEN=bidmart-local-internal-token

# RabbitMQ (shared CloudAMQP in prod/staging; same URL as Heroku auth/order CLOUDAMQP_URL)
SPRING_RABBITMQ_ADDRESSES=amqp://guest:guest@localhost:5672/%2f
BIDMART_EVENTS_EXCHANGE=bidmart.events

# Swagger UI (docker-compose)
SWAGGER_UI_PORT=8088
